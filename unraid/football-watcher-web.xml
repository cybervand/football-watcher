<?xml version="1.0"?>
<!--
  Football Watcher — WEB container (React UI + Node server).
  Pulls a prebuilt image from Docker Hub (like any Unraid app). Gets its own IP
  on br1 (192.168.1.123) and reaches the translator at its br1 IP
  (http://192.168.1.124:8788). Both containers on br1 — simple single-network
  install, no custom bridge, no dual-network reboot bug.
-->
<Container version="2">
  <Name>football-watcher-web</Name>
  <Repository>talentlesshack/football-watcher:latest</Repository>
  <Registry>https://hub.docker.com/r/talentlesshack/football-watcher/</Registry>
  <!-- Primary network: br1 macvlan, so the web UI gets its own LAN IP. -->
  <Network>br1</Network>
  <MyIP>192.168.1.123</MyIP>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project/>
  <Overview>Live FIFA World Cup 2026 tracker: live scores (NIFS/NRK), day-grouped matches, group standings, auto-advancing knockout bracket, and match summaries with an EN/NO toggle. Proxies /api/translate to the translator container.</Overview>
  <Category>MediaApp:Other Tools:</Category>
  <WebUI>http://[IP]:[PORT:80]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/cybervand/football-watcher/main/unraid/football-watcher-web.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/cybervand/football-watcher/main/unraid/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <DateInstalled/>
  <Requires/>
  <Config
    Name="PORT"
    Target="PORT"
    Default="80"
    Mode=""
    Description="Port the web UI listens on (its own br1 IP)."
    Type="Variable"
    Display="always"
    Required="true"
    Mask="false">80</Config>
  <Config
    Name="TRANSLATOR_URL"
    Target="TRANSLATOR_URL"
    Default="http://192.168.1.124:8788"
    Mode=""
    Description="Where to reach the translator container (its br1 IP:port)."
    Type="Variable"
    Display="advanced"
    Required="true"
    Mask="false">http://192.168.1.124:8788</Config>
  <Config
    Name="LOG_LEVEL"
    Target="LOG_LEVEL"
    Default="info"
    Mode=""
    Description="Logging verbosity: error | warn | info | debug."
    Type="Variable"
    Display="advanced"
    Required="false"
    Mask="false">info</Config>
</Container>
