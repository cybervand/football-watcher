<?xml version="1.0"?>
<!--
  Football Watcher — TRANSLATOR container (NorT5 Norwegian->English, internal).
  Add via Docker tab -> Add Container -> paste this template (or drop it in
  /boot/config/plugins/dockerMan/templates-user/). Internal only: no WebUI, no
  ports. The WEB container reaches it by name at http://translator:8788 over the
  shared 'football-watcher' bridge network.

  Run the TRANSLATOR FIRST so the network exists, then the web container.
-->
<Container version="2">
  <Name>football-watcher-translator</Name>
  <Repository>talentlesshack/nort5-translator:latest</Repository>
  <Registry>https://hub.docker.com/r/talentlesshack/nort5-translator/</Registry>
  <!-- Own IP on br1 (no custom network needed). The web container reaches it
       directly at http://192.168.1.124:8788. Both containers on br1 = simple
       GUI install, no dual-network reboot bug. -->
  <Network>br1</Network>
  <MyIP>192.168.1.124</MyIP>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project/>
  <Overview>NorT5 Norwegian-&gt;English translation service for Football Watcher. The web container calls it at its br1 IP (http://192.168.1.124:8788). Runs the model in ONNX Runtime; first request loads the model (~3s) then stays warm.</Overview>
  <Category>MediaApp:Other Tools:</Category>
  <WebUI/>
  <TemplateURL>https://raw.githubusercontent.com/cybervand/football-watcher/main/unraid/football-watcher-translator.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/cybervand/football-watcher/main/unraid/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <DateInstalled/>
  <Requires/>
  <Config
    Name="TRANSLATOR_PORT"
    Target="TRANSLATOR_PORT"
    Default="8788"
    Mode=""
    Description="Internal port the translator listens on. Not exposed to the LAN."
    Type="Variable"
    Display="advanced"
    Required="false"
    Mask="false">8788</Config>
</Container>
