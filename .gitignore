# Dependencies & build output (regenerated by npm / vite)
node_modules/
dist/

# Logs & caches
*.log
npm-debug.log*
.vite/

# Editor / OS cruft
.DS_Store
.vscode/
.idea/
*.swp

# Playwright (dev-only verification tooling)
playwright-report/
test-results/

# Scratch output from the one-time tokenizer conversion — not part of the app
_tok_out/

# The translation model lives in the translator image (Docker Hub), NOT in git.
server/models/

# NorT5 conversion scratch / probe files
_nort5src/
_nort5venv/
_nort5onnx/

# Python build cruft
__pycache__/
*.pyc
